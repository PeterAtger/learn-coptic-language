              "For Singular (Both)",
              "[c]Ou[/c]"
            ],
            [
              "Books",
              "[c]|anjwm[/c]",
              "A garden",
              "[c]Ouswm[/c]"
            ],
            [
              "Pens",
              "[c]|anka][/c]",
              "A moon",
              "[c]Ouio\\[/c]"
            ]
          ]
        }
      },
      {
        "type": "note",
        "title": "Independent Personal Pronouns",
        "content": "Used in nominal sentences to express different personal pronouns (First, Second, Third person). They often act as the subject."
      },
      {
        "type": "table",
        "title": "Independent Personal Pronouns",
        "isLegacy": false,
        "table": {
          "headers": [
            "",
            "Independent Personal Pronouns",
            "",
            ""
          ],
          "rows": [
            [
              "We",
              "[c]Anon[/c]",
              "I",
              "[c]Anok[/c]"
            ],
            [
              {
                "value": "You (Plural)",
                "rowSpan": 2
              },
              {
                "value": "[c]` Nqwten[/c]",
                "rowSpan": 2
              },
              "You (Masc. Sing.)",
              "[c]` Nqok[/c]"
            ],
            [
              "You (Fem. Sing.)",
              "[c]` Nqo[/c]"
            ],
            [
              {
                "value": "They",
                "rowSpan": 2
              },
              {
                "value": "[c]` Nqwou[/c]",
                "rowSpan": 2
              },
              "He",
              "[c]` Nqof[/c]"
            ],
            [
              "She",
              "[c]` Nqoc[/c]"
            ]
          ]
        }
      },
      {
        "type": "note",
        "title": "Copulas (To Be)",
        "content": "Copulas connect two nouns (subject and predicate) in nominal sentences."
      },
      {
        "type": "table",
        "title": "",
        "isLegacy": false,
        "table": {
          "headers": [],
          "rows": [
            [
              "Plural (Both)",
              "Fem. Singular",
              "Masc. Singular"
            ],
            [
              "[c]Ne[/c]",
              "[c]Te[/c]",
              "[c]Pe[/c]"
            ],
            [
              "They are / We are",
              "She is / It is / I am",
              "He is / It is / I am"
            ]
          ]
        }
      },
      {
        "type": "table",
        "title": "",
        "isLegacy": false,
        "table": {
          "headers": [
            "",
            "",
            "Important Notes",
            ""
          ],
          "rows": [
            [
              {
                "value": "If the predicate is definite, the copula is placed between the subject and the predicate.",
                "colSpan": 2
              },
              {
                "value": "If the predicate is indefinite, the copula is placed AFTER the predicate.",
                "colSpan": 2
              }
            ],
            [
              "[c]` Nqo te ;]ourh[/c]",
              "You are the censer",
              "[c]` Vnou; ouagaph pe[/c]",
              "God is love"
