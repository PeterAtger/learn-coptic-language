[
  {
    "id": "p34-intro",
    "title": "General Rules",
    "stageIds": [
      "primary34"
    ],
    "sections": [
      {
        "type": "note",
        "title": "",
        "content": "The Coptic alphabet consists of 32 letters divided as follows:"
      },
      {
        "type": "table",
        "title": "",
        "isLegacy": false,
        "table": {
          "headers": [
            "",
            "Division of Coptic Alphabet",
            ""
          ],
          "rows": [
            [
              "24 Consonants",
              "7 Vowels",
              "[c]<?[/c] (So) used as number 6 only"
            ]
          ]
        }
      },
      {
        "type": "note",
        "title": "",
        "content": "The [c]`[/c] (Jenkim) is a mark drawn as ( [c]`[/c] ) or ( [c]~[/c] ). When placed on a consonant, it is pronounced as [c]E[/c]. If placed on a vowel, it indicates the independence of that vowel's pronunciation."
      },
      {
        "type": "table",
        "title": "Vowels are divided into:",
        "isLegacy": false,
        "table": {
          "headers": [
            "",
            "Vowel Divisions",
            ""
          ],
          "rows": [
            [
              "Open Vowels",
              "Rounded Vowels",
              "Closed Vowels"
            ],
            [
              "[c]A[/c]",
              "[c]W - O[/c]",
              "[c]E - H - I - U[/c]"
            ]
          ]
        }
      }
    ]
  },
  {
    "id": "p34-lvl1",
    "title": "Level 1",
    "stageIds": [
      "primary34"
    ],
    "sections": [
      {
        "type": "note",
        "title": "",
        "content": "Differentiating between Coptic words and Greek words"
      },
      {
        "type": "table",
        "title": "",
        "isLegacy": false,
        "table": {
          "headers": [
            "",
            "Coptic vs Greek",
            ""
          ],
          "rows": [
            [
              {
                "value": "Seven letters usually appear in Coptic words: \n [c] (]-f-'-\\-j-s-;) [/c]",
                "rowSpan": 2
              },
              "Earth",
              "[c]Ka\\i[/c]"
            ],
            [
              "Milk",
              "[c]`Erw;[/c]"
            ],
            [
              {
                "value": "Five letters usually appear in Greek words: \n [c](g-d-z-[-y)[/c]",
                "rowSpan": 2
              },
              "Earth",
              "[c]Gh[/c]"
            ],
            [
              "Milk",
              "[c]Gala[/c]"
            ],
            [
              "Words where the letter [c]u[/c] is pronounced as (y) are usually Greek words.",
              "Soul",
              "[c]Yuxh[/c]"
            ],
            [
              {
                "value": "A word can be Greek if it ends with one of these suffixes: \n [c] ac - oc - hc - an - on - hn[/c]",
                "rowSpan": 2
              },
              "Angel",
              "[c]Aggeloc[/c]"
            ],
            [
              "Christ",
              "[c]PiXrictoc[/c]"
            ]
          ]
        }
      },
      {
        "type": "table",
        "title": "Important Notes",
        "isLegacy": false,
        "table": {
          "headers": [
            "",
            "Important Notes",
            ""
          ],
          "rows": [
            [
              {
                "value": "The letters [c]y - z - [[/c] appear in Greek words, but in rare cases they can appear in Coptic words.",
                "rowSpan": 3
              },
              "School",
              "[c]Anzhb[/c]"
            ],
            [
              "Number 9",
              "[c]Yit[/c]"
            ],
            [
              "Curtain",
              "[c]Li[[/c]"
            ],
            [
              "The letter [c]|[/c] appears in Coptic words only, but it is sometimes used before Greek words to represent the Greek aspiration mark.",
              "Peace",
              "[c]|irhnh[/c]"
            ]
          ]
        }
      },
      {
        "type": "note",
        "title": "Articles (Definite and Indefinite)",
        "content": "When a noun is used in a sentence, it is preceded by a definite or indefinite article. These articles are always attached to the noun."
      },
      {
        "type": "table",
        "title": "First: Definite Articles",
        "isLegacy": false,
        "table": {
          "headers": [
            "Definite Articles",
            "",
            "",
            ""
          ],
          "rows": [
            [
              "Description",
              "Plural",
              "Feminine Singular",
              "Masculine Singular"
            ],
            [
              "General Definite Articles",
              "[c]Ni[/c]",
              "[c]:[/c]",
              "[c]Pi[/c]"
            ],
            [
              {
                "value": "Special article for words starting with these letters: \n [c] B - I - L - M - N - Ou - R[/c]",
                "colSpan": 1
              },
              "",
              "[c]` Q[/c]",
              "[c]` V[/c]"
            ],
            [
              {
                "value": "Special article for words NOT starting with these letters: \n [c]B - I - L - M - N - Ou - R[/c]",
                "colSpan": 1
              },
              "",
              "[c]` T[/c]",
              "[c]` P[/c]"
            ],
            [
              "Special article for added plural nouns",
              "[c]Nen[/c]",
              "",
              ""
            ]
          ]
        }
      },
      {
        "type": "table",
        "title": "Examples of Definite Articles:",
        "isLegacy": false,
        "table": {
          "headers": [
            "",
            "",
            "Examples of Definite Articles",
            "",
            "",
            ""
          ],
          "rows": [
            [
              "The eyes",
              "[c]Nibal[/c]",
              "The church",
              "[c]:ekklhcia[/c]",
              "The Spirit",
              "[c]Pi`pneuma[/c]"
            ],
            [
              "The fingers",
              "[c]Nithb[/c]",
              "The hand",
              "[c]` Tjij[/c]",
              "The life",
              "[c]` Pwn'[/c]"
            ],
            [
              "The oranges",
              "[c]Nimanmon[/c]",
              "The mother",
              "[c]` Qmau[/c]",
              "The people",
              "[c]` Vlaoc[/c]"
            ],
            [
              {
                "value": "The priests of the church",
                "colSpan": 3
              },
              {
                "value": "[c]Nenouhb `n;ekklhcia[/c]",
                "colSpan": 3
              }
            ]
          ]
        }
      },
      {
        "type": "table",
        "title": "Articles can sometimes distinguish meanings for words with multiple meanings:",
        "isLegacy": false,
        "table": {
          "headers": [
            "",
            "Distinguishing meanings with articles",
            "",
            ""
          ],
          "rows": [
            [
              "Barley",
              "[c]Piiwt[/c]",
              "The Father",
              "[c]` Viwt[/c]"
            ],
            [
              "Winepress",
              "[c]Piiom[/c]",
              "The Sea",
              "[c]` Viom[/c]"
            ]
          ]
        }
      },
      {
        "type": "note",
        "title": "Second: Indefinite Articles",
        "content": "These are used before nouns that do not have a definite article to make them indefinite."
      },
      {
        "type": "table",
        "title": "Indefinite Articles",
        "isLegacy": false,
        "table": {
          "headers": [
